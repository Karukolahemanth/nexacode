# ═══════════════════════════════════════════════════
# NexusIDE Backend — Environment Variables Template
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:your-password@your-host:5432/postgres

# LLM Backend
LLM_PROVIDER=vllm
VLLM_URL=https://your-runpod-endpoint/v1
VLLM_MODEL=Qwen/Qwen3-35B-A3B
VLLM_API_KEY=your-api-key

# Ollama (alternative to vLLM)
OLLAMA_URL=

# Auth
JWT_SECRET=change-this-to-a-random-64-char-string

# CORS (comma-separated)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Optional
REDIS_URL=
QDRANT_URL=
DEBUG=false
